{
  "name": "@marketintellabs/hermes-paperclip-adapter",
  "version": "0.4.0-mil.0",
  "description": "MarketIntelLabs fork of the Paperclip adapter for Hermes Agent — with adapter-owned status transitions, published 0.3.1+ release, MIL heartbeat prompt templates, and OpenRouter model-prefix hints",
  "type": "module",
  "license": "MIT",
  "author": "MarketIntelLabs Inc. (fork of NousResearch/hermes-paperclip-adapter)",
  "repository": {
    "type": "git",
    "url": "https://github.com/marketintellabs/hermes-paperclip-adapter"
  },
  "bugs": {
    "url": "https://github.com/marketintellabs/hermes-paperclip-adapter/issues"
  },
  "homepage": "https://github.com/marketintellabs/hermes-paperclip-adapter#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "paperclip",
    "hermes",
    "hermes-agent",
    "ai-agent",
    "adapter",
    "orchestration",
    "marketintellabs"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server/index.js",
    "./ui": "./dist/ui/index.js",
    "./cli": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "UPSTREAM.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "tsc && node --test dist/**/*.test.js",
    "clean": "rm -rf dist",
    "prepare": "tsc"
  },
  "dependencies": {
    "@paperclipai/adapter-utils": "^2026.325.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
